# PostHog Analytics Configuration (optional)
# Set these in your build environment or CI to enable analytics
# These keys are NOT exposed to users - analytics only works in official builds
#
# GITHUB SECRETS SETUP:
#   1. Go to Settings → Secrets and variables → Actions
#   2. Add repository secrets:
#      - VITE_POSTHOG_KEY (optional) - Your PostHog project API key
#      - VITE_POSTHOG_HOST (optional) - PostHog API host (defaults to EU cloud)
#   3. These are automatically injected during GitHub Actions builds
#   4. Forks without these secrets will have analytics disabled
#
# Get your PostHog key: https://app.posthog.com/project/settings

VITE_POSTHOG_KEY=phc_your_project_key_here

# PostHog API Host (defaults to EU cloud: https://eu.i.posthog.com)
# Change this if you self-host PostHog or use US cloud
VITE_POSTHOG_HOST=https://eu.i.posthog.com
